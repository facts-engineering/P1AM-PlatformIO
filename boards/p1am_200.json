    "f_cpu": "120000000L",
    "hwids": [
      ["0x1354", "0x4002"],
      ["0x1354", "0x4003"],
      ["0x1354", "0x4004"]
    ],
    "mcu": "samd51p20a",
    "usb_product": "P1AM-200",
    "usb_vid": "0x1354",
    "usb_pid": "0x4002",
    "variant": "P1AM-200"
  },
  "debug": {
    "jlink_device": "ATSAMD51P20A",
    "openocd_chipname": "at91samd51p20",
